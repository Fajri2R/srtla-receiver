# Base URL for the API server
# This will be used by the management app to make API calls
APP_URL=http://your.public.ip.address:8080

# Ports
SRT_PLAYER_PORT=4000
SRT_SENDER_PORT=4001
SLS_STATS_PORT=8080
SRTLA_PORT=5000
SLS_MGNT_PORT=8123

# Log
SRTLA_LOG_LEVEL=debug

# ── Live Preview ─────────────────────────────────────────────────
# Port for the Live Preview web UI (http://your-server:8090)
LIVE_PREVIEW_PORT=8090

# Stream ID to transcode for live preview.
# Must match the stream ID used by the publisher (e.g. live/stream or live/mystream)
PREVIEW_STREAM_ID=live/stream

# HLS segment duration in seconds (lower = less latency, higher = more stable)
HLS_SEGMENT_TIME=2

# Number of HLS segments to keep in the playlist (window size)
HLS_LIST_SIZE=5